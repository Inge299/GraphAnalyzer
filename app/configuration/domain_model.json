  "edge_types": [
    {
      "id": "owns",
      "label": "Владеет",
      "default_visual": {
        "color": "#334155",
        "width": 2,
        "direction": "to",
        "dashed": false
      },
      "allowed_from": ["person"],
      "allowed_to": ["phone", "sim", "bank_card", "vehicle", "passport", "email", "social_id"]
    },
    {
      "id": "uses",
      "label": "Использует",
      "default_visual": {
        "color": "#2563eb",
        "width": 2,
        "direction": "to",
        "dashed": false
      },
      "allowed_from": ["person", "phone"],
      "allowed_to": ["sim", "ip", "email", "social_id"]
    },
    {
      "id": "located_at",
      "label": "Находится",
      "default_visual": {
        "color": "#0f766e",
        "width": 2,
        "direction": "to",
        "dashed": true
      },
      "allowed_from": ["person", "phone", "vehicle"],
      "allowed_to": ["address", "location"]
    },
    {
      "id": "connected_to",
      "label": "Связан",
      "default_visual": {
        "color": "#475569",
        "width": 2,
        "direction": "both",
        "dashed": false
      },
      "allowed_from": ["*"],
      "allowed_to": ["*"]
    }
  ],
  "rules": {
    "merge_nodes_with_same_label": true,
    "allow_parallel_edges": true,
    "edge_direction_values": ["from", "to", "both"],
    "edge_style_values": ["solid", "dashed"]
  }
}