# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@osint-postgres:5432/osint_graph
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=osint_graph

# Redis Configuration
REDIS_URL=redis://osint-redis:6379/0

# Application Settings
SECRET_KEY=dev-secret-key-for-development
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# CORS Settings
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5000"]

# Celery Settings
CELERY_BROKER_URL=redis://osint-redis:6379/1
CELERY_RESULT_BACKEND=redis://osint-redis:6379/2

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB
